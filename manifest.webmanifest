{
  "$schema": "https://json.schemastore.org/web-manifest-combined.json",

  "name":        "NEXUS BLOCKS",
  "short_name":  "NEXUS",
  "description": "A clean, addictive block-puzzle game: drag pieces onto the 8×8 grid, clear lines and columns, and chain combos for a high score. Plays entirely offline.",

  "id":        "nexus-blocks-v1",
  "start_url": "/?source=pwa",
  "scope":     "/",

  "display":          "standalone",
  "display_override": ["window-controls-overlay", "standalone", "minimal-ui"],

  "orientation":      "portrait-primary",

  "theme_color":      "#6600FF",
  "background_color": "#0A0A0F",

  "lang":              "en-US",
  "dir":               "ltr",
  "categories":        ["games", "puzzle", "entertainment"],

  "iarc_rating_id": "e84b072d-71b3-4d3e-86ae-31a8ce4e53b7",

  "icons": [
    {
      "src":     "/icons/icon-16.png",
      "sizes":   "16x16",
      "type":    "image/png",
      "purpose": "any"
    },
    {
      "src":     "/icons/icon-32.png",
      "sizes":   "32x32",
      "type":    "image/png",
      "purpose": "any"
    },
    {
