    },
    {
      "src":     "/icons/maskable-192.png",
      "sizes":   "192x192",
      "type":    "image/png",
      "purpose": "maskable"
    },
    {
      "src":     "/icons/maskable-512.png",
      "sizes":   "512x512",
      "type":    "image/png",
      "purpose": "maskable"
    },
    {
      "src":     "/icons/icon.svg",
      "sizes":   "any",
      "type":    "image/svg+xml",
      "purpose": "any maskable"
    }
